{
  "name": "rest-api-node-ts-server",
  "version": "1.0.0",
  "description": "REST API's con Express y TypeScript",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src",
    "test": "jest --detectOpenHandles",
    "test:coverage": "yarn pretest && yarn jest --detectOpenHandles --coverage",
    "pretest": "ts-node src/data --clear",
    "docker": "docker compose down --volumes && docker compose build --no-cache && docker compose up -d",
    "build": "tsc"
  },
  "author": "Christopher Reyes",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/validator": "^13.15.10",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "colors": "^1.4.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "morgan": "^1.11.0",
    "openapi-types": "^12.1.3",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  }
}
